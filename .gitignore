agent/knowledge_base/faiss_index/
agent/knowledge_base/pdfs/*.pdf

# --- Jupyter Notebooks ---
**/.ipynb_checkpoints/
**/_checkpoint*

# --- IDEs & OS ---
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Docker ---
*.tar
docker-compose.override.yml
*.log
*.bat

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Terraform ---
**/.terraform/
*.tfstate
*.tfstate.backup
**/.terraform.lock.hcl
terraform/terraform.tfvars
terraform/*.auto.tfvars
terraform/crash.log

# --- Python ---
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/*.egg-info/
tmp_*.py
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
agent/test_env/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# --- AI & Knowledge Base ---

"""
main.py — FastAPI application for AWS Bedrock AgentCore Runtime.

Exposes:
  GET  /ping          – Health check (required by AgentCore)
  POST /invocations   – Agent invocation with SSE streaming
"""

import sys
import os

# --- EMERGENCY LOGGING ---
print(">>> CONTAINER BOOTING: Python unbuffered output enabled.", flush=True)
sys.stdout.flush()
# -------------------------

import json
import logging
import os
import uuid
from typing import AsyncGenerator

from fastapi import Depends, FastAPI, HTTPException, Request
from fastapi.responses import JSONResponse
from sse_starlette.sse import EventSourceResponse
from pydantic import BaseModel, Field

from agent.graph import create_agent_graph
from agent.observability import get_langfuse_handler
from auth.cognito import get_current_user, UserContext

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
LOG_LEVEL = os.environ.get("LOG_LEVEL", "INFO")
logging.basicConfig(level=LOG_LEVEL, format="%(asctime)s %(levelname)s %(name)s: %(message)s")
logger = logging.getLogger(__name__)

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
app = FastAPI(
    title="Stock Agent API",
    description="AI agent for real-time & historical stock analysis with RAG on Amazon financials",
    version="1.0.0",
)

# Build the LangGraph agent once at startup
agent_graph = None


@app.on_event("startup")
async def startup():
    global agent_graph
    logger.info("Building LangGraph agent...")
    agent_graph = create_agent_graph()
    logger.info("Agent graph ready.")


# ---------------------------------------------------------------------------
# Schemas
# ---------------------------------------------------------------------------
class InvocationRequest(BaseModel):
    query: str = Field(..., description="User question")
    thread_id: str = Field(
        default_factory=lambda: str(uuid.uuid4()),
        description="Conversation thread ID for session continuity",
    )


# ---------------------------------------------------------------------------
# Health Check
# ---------------------------------------------------------------------------
@app.get("/ping")
async def ping():
    """Health check endpoint required by AgentCore Runtime."""
    return {"status": "healthy"}


# ---------------------------------------------------------------------------
# Agent Invocation (SSE streaming)
# ---------------------------------------------------------------------------
@app.post("/invocations")
async def invocations(
    body: InvocationRequest,
    user: UserContext = Depends(get_current_user),
):
    """
    Main agent endpoint. Accepts a user query and streams the response
    as Server-Sent Events.
    """
    logger.info(f"Invocation from user={user.user_id} query={body.query!r}")

    if agent_graph is None:
        raise HTTPException(status_code=503, detail="Agent not initialised yet")

    # Langfuse callback for this invocation
    langfuse_handler = get_langfuse_handler(
        user_id=user.user_id,
        session_id=body.thread_id,
        trace_name="stock-agent-invocation",
    )

    async def event_stream() -> AsyncGenerator[dict, None]:
        """Async generator that yields SSE events from the LangGraph agent."""
        config = {
            "configurable": {"thread_id": body.thread_id},
            "callbacks": [langfuse_handler] if langfuse_handler else [],
        }

        input_messages = {"messages": [("user", body.query)]}

        try:
            async for event in agent_graph.astream_events(
                input_messages,
                config=config,
                version="v2",
            ):
                kind = event["event"]

                # Stream LLM tokens as they arrive
                if kind == "on_chat_model_stream":
                    content = event["data"]["chunk"].content
                    if content:
                        yield {
                            "event": "token",
                            "data": json.dumps({"type": "token", "content": content}),
                        }

                # Stream tool call results
                elif kind == "on_tool_end":
                    tool_output = event["data"].get("output", "")
                    tool_name = event.get("name", "unknown_tool")
                    yield {
                        "event": "tool_result",
                        "data": json.dumps({
                            "type": "tool_result",
                            "tool": tool_name,
                            "content": str(tool_output)[:2000],  # Truncate large outputs
                        }),
                    }

                # Stream node transitions
                elif kind in ("on_chain_start", "on_chain_end"):
                    node_name = event.get("name", "")
                    if node_name and node_name not in ("LangGraph", "RunnableSequence"):
                        yield {
                            "event": "status",
                            "data": json.dumps({
                                "type": "status",
                                "node": node_name,
                                "status": "started" if kind == "on_chain_start" else "completed",
                            }),
                        }

            # Signal end of stream
            yield {"event": "done", "data": json.dumps({"type": "done"})}

        except Exception as e:
            logger.exception("Error during agent invocation")
            yield {
                "event": "error",
                "data": json.dumps({"type": "error", "message": str(e)}),
            }

        finally:
            # Flush Langfuse traces
            if langfuse_handler:
                langfuse_handler.flush()

    return EventSourceResponse(event_stream())


# ---------------------------------------------------------------------------
# Error handlers
# ---------------------------------------------------------------------------
@app.exception_handler(HTTPException)
async def http_exception_handler(request: Request, exc: HTTPException):
    return JSONResponse(
        status_code=exc.status_code,
        content={"error": exc.detail},
    )
